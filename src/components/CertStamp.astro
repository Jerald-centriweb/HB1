---
import SilverFern from './SilverFern.astro';

interface Props {
  mark: string;       // centre mark (e.g. MGO) or ignored when fern
  top?: string;       // curved text along the top rim
  bottom?: string;    // curved text along the bottom rim
  fern?: boolean;     // render a silver fern in the centre instead of text
  size?: number;
}
const { mark, top = '', bottom = '', fern = false, size = 96 } = Astro.props;
const uid = mark.replace(/[^a-z0-9]/gi, '').toLowerCase();
const big = mark.length >= 5 ? 13 : 21;
---

<div class="cert-stamp" style={`position:relative;width:${size}px;height:${size}px;margin:0 auto;filter:drop-shadow(0 6px 14px rgba(0,0,0,.5));`}>
  <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false" style="position:absolute;inset:0;width:100%;height:100%;overflow:visible;">
    <defs>
      <linearGradient id={`csg-${uid}`} x1="0" y1="0" x2="0" y2="1">
        <stop offset="0" stop-color="#f9e29a" />
        <stop offset="0.5" stop-color="#e0b552" />
        <stop offset="1" stop-color="#b9821f" />
      </linearGradient>
      <radialGradient id={`csr-${uid}`} cx="50%" cy="34%" r="62%">
        <stop offset="0" stop-color="rgba(243,205,107,0.16)" />
        <stop offset="100%" stop-color="rgba(243,205,107,0)" />
      </radialGradient>
      <path id={`cs-top-${uid}`} d="M50,50 m-36,0 a36,36 0 1,1 72,0 a36,36 0 1,1 -72,0" fill="none" />
      <path id={`cs-bot-${uid}`} d="M50,50 m-36,0 a36,36 0 1,0 72,0 a36,36 0 1,0 -72,0" fill="none" />
    </defs>

    <!-- medallion fill + rings -->
    <circle cx="50" cy="50" r="47" fill={`url(#csr-${uid})`} />
    <circle cx="50" cy="50" r="47" fill="none" stroke={`url(#csg-${uid})`} stroke-width="2" />
    <circle cx="50" cy="50" r="42.5" fill="none" stroke="#d8ac4e" stroke-opacity="0.55" stroke-width="0.7" />
    <circle cx="50" cy="50" r="29.5" fill="none" stroke="#d8ac4e" stroke-opacity="0.5" stroke-width="0.9" />

    <!-- curved rim text -->
    {top && (
      <text font-family="'Barlow Condensed',sans-serif" font-size="6.3" font-weight="600" letter-spacing="1.1" fill="#e7c879">
        <textPath href={`#cs-top-${uid}`} startOffset="25%" text-anchor="middle">{top}</textPath>
      </text>
    )}
    {bottom && (
      <text font-family="'Barlow Condensed',sans-serif" font-size="6.3" font-weight="600" letter-spacing="1.1" fill="#e7c879">
        <textPath href={`#cs-bot-${uid}`} startOffset="25%" text-anchor="middle">{bottom}</textPath>
      </text>
    )}

    <!-- side ornaments separating the rim words -->
    <path d="M87,50 l1.6,2.4 l-1.6,2.4 l-1.6,-2.4 z" transform="translate(0,-2.4)" fill="#d8ac4e" />
    <path d="M13,50 l1.6,2.4 l-1.6,2.4 l-1.6,-2.4 z" transform="translate(0,-2.4)" fill="#d8ac4e" />
  </svg>

  <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;">
    {fern ? (
      <SilverFern size={20} />
    ) : (
      <span style={`font-family:'Archivo Black';font-size:${big}px;letter-spacing:.5px;background:linear-gradient(180deg,#f9e29a,#d99f2c);-webkit-background-clip:text;background-clip:text;color:transparent;`}>{mark}</span>
    )}
  </div>
</div>
