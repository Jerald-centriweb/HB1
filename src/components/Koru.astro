---
/**
 * Koru.astro — Māori koru (unfurling spiral) as inline SVG
 *
 * The koru is a deeply significant Māori symbol representing new life, growth,
 * strength, and peace. It is inspired by the shape of a new silver fern frond
 * as it unfurls. This SVG renders a graceful, dignified single spiral that
 * bulbs at the centre and tapers as it unrolls outward and upward.
 *
 * Construction:
 *   - Centre circle: tight closed loop (the bulb), radius ~12 at centre (50,58)
 *   - Spiral path: leaves the bulb, sweeps outward counter-clockwise in a
 *     smooth arc, then the stalk rises and curves gently to one side —
 *     the classic koru silhouette as seen in Māori tā moko and tukutuku art.
 *   - Single open path, stroke only, round caps/joins for softness.
 *   - No fill — respects the symbol's graphic tradition of being defined by line.
 *
 * viewBox: 0 0 100 100
 */

interface Props {
  /** Width (and height) in pixels */
  size?: number;
  /** Overall opacity */
  opacity?: number;
  class?: string;
}

const {
  size = 80,
  opacity = 1,
  class: className,
} = Astro.props;
---

<svg
  viewBox="0 0 100 100"
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  aria-hidden="true"
  focusable="false"
  class:list={['koru', className]}
  style={`opacity:${opacity};display:block;`}
>


  <path
    d="
      M62,8
      C62,18 66,30 68,42
      C70,54 68,64 60,70
      C52,76 38,76 30,68
      C22,60 22,46 30,38
      C38,30 52,30 60,38
      C65,43 66,50 63,56
      C60,62 54,65 48,64
      C42,63 38,58 38,52
      C38,46 42,42 48,42
      C54,42 57,46 57,52
      C57,56 54,59 51,59
    "
    fill="none"
    stroke="#d8ac4e"
    stroke-width="6"
    stroke-linecap="round"
    stroke-linejoin="round"
  />
</svg>

<style>
  .koru {
    overflow: visible;
  }
</style>
