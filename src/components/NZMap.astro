---
/**
 * NZMap.astro — Recognisable outline map of New Zealand (North + South + Stewart Islands)
 *
 * Path source: Coordinates derived from the johan/world.geo.json dataset
 * (https://github.com/johan/world.geo.json/blob/master/countries/NZL.geo.json)
 * which is itself simplified from Natural Earth public domain data.
 * Converted to SVG space: viewBox "0 0 220 480"
 *   x = (lon - 166) × 16.08 + 5
 *   y = (|lat| - 34) × 34.81 + 5
 * All conversion math independently verified against key geographic anchors:
 *   East Cape 178.5°E → x≈206 (near right edge ✓)
 *   Fiordland 166.7°E → x≈16 (near left edge ✓)
 *   Cape Reinga 34.5°S → y≈23 (near top ✓)
 *   Bluff 46.6°S → y≈444 (near bottom ✓)
 */

interface Props {
  /** Array of apiary region markers rendered on the map */
  regions?: Array<{ label: string; x: number; y: number }>;
  class?: string;
}

const {
  regions = [
    { label: 'East Cape',       x: 200, y: 136 },
    { label: 'Coromandel',      x: 163, y: 106 },
    { label: 'Central Plateau', x: 150, y: 195 },
    { label: 'West Coast',      x:  75, y: 301 },
    { label: 'Southland',       x:  72, y: 410 },
  ],
  class: className,
} = Astro.props;
---

<svg
  viewBox="0 0 220 480"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="nzmap-title"
  class:list={['nz-map', className]}
  style="width:100%;max-width:280px;height:auto;display:block;"
>
  <title id="nzmap-title">New Zealand</title>
  <defs>
    <radialGradient id="nzmap-dot-halo" cx="50%" cy="50%" r="50%">
      <stop offset="0%"   stop-color="#d8ac4e" stop-opacity="0.55" />
      <stop offset="100%" stop-color="#d8ac4e" stop-opacity="0" />
    </radialGradient>
  </defs>

  <path
    aria-hidden="true"
    fill="rgba(216,172,78,0.07)"
    stroke="#d8ac4e"
    stroke-width="1.5"
    stroke-linejoin="round"
    stroke-linecap="round"
    d="
      M143.5,80.1 L155.1,116.7 L155.5,92.9 L162.7,102.4 L165.1,128.8
      L178.1,140.1 L188.9,142.9 L198.1,129.6 L206.3,133.6 L202.4,164.5
      L197.5,184.8 L185.2,184.1 L180.9,194.7 L182.4,209.7 L180.0,216.2
      L174.0,234.9 L166.0,258.8 L153.6,272.6 L150.8,263.5 L144.1,258.5
      L153.4,229.8 L148.1,210.7 L130.8,196.8 L131.3,184.2 L142.9,172.0
      L145.6,145.2 L144.8,122.7 L138.3,99.4 L138.8,93.2 L131.1,78.9
      L118.4,48.1 L111.7,23.4 L117.7,20.7 L126.4,40.0 L138.9,49.1
      L143.5,80.1 Z
    "
  />

  <path
    aria-hidden="true"
    fill="rgba(216,172,78,0.07)"
    stroke="#d8ac4e"
    stroke-width="1.5"
    stroke-linejoin="round"
    stroke-linecap="round"
    d="
      M117.9,245.9 L121.5,260.2 L133.0,246.1 L137.6,260.8 L137.6,275.5
      L131.7,291.6 L121.1,317.2 L112.9,331.2 L118.8,348.0 L106.4,348.4
      L92.7,361.5 L88.4,384.3 L79.2,419.5 L66.6,435.1 L58.6,445.0
      L43.8,444.3 L33.4,432.8 L15.9,430.4 L13.2,417.6 L21.8,391.8
      L42.0,357.4 L52.4,350.9 L64.0,337.6 L77.8,319.4 L87.4,301.3
      L94.6,275.4 L100.7,266.6 L103.0,247.1 L114.3,231.1 L117.9,245.9 Z
    "
  />

  <ellipse
    aria-hidden="true"
    cx="39"
    cy="458"
    rx="11"
    ry="8"
    fill="rgba(216,172,78,0.07)"
    stroke="#d8ac4e"
    stroke-width="1.4"
  />

  {regions.map(({ label, x, y }) => (
    <g class="nzmap-region" aria-label={label}>
      <circle cx={x} cy={y} r="9" fill="url(#nzmap-dot-halo)" aria-hidden="true" />
      <circle cx={x} cy={y} r="3.5" fill="#d8ac4e" class="nzmap-dot" aria-hidden="true" />
      <text
        x={x}
        y={y - 10}
        text-anchor="middle"
        font-family="sans-serif"
        font-size="6.5"
        fill="#cdbfa3"
        letter-spacing="0.08em"
        font-weight="500"
        aria-hidden="true"
        style="text-transform:uppercase;"
      >
        {label}
      </text>
    </g>
  ))}
</svg>

<style>
  .nz-map { overflow: visible; }

  @keyframes nzmap-pulse {
    0%   { r: 3.5; opacity: 1; }
    60%  { r: 5.5; opacity: 0.5; }
    100% { r: 3.5; opacity: 1; }
  }

  .nzmap-dot {
    animation: nzmap-pulse 2.8s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }

  .nzmap-region:nth-child(1) .nzmap-dot { animation-delay: 0s; }
  .nzmap-region:nth-child(2) .nzmap-dot { animation-delay: 0.56s; }
  .nzmap-region:nth-child(3) .nzmap-dot { animation-delay: 1.12s; }
  .nzmap-region:nth-child(4) .nzmap-dot { animation-delay: 1.68s; }
  .nzmap-region:nth-child(5) .nzmap-dot { animation-delay: 2.24s; }
</style>
