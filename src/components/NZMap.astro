---
/**
 * NZMap.astro — Recognisable outline map of New Zealand (North + South + Stewart Islands)
 *
 * Path source: Derived from the Wikimedia Commons "New Zealand Simplified.svg"
 * (CC0 public domain, https://commons.wikimedia.org/wiki/File:New_Zealand_Simplified.svg)
 * Original viewBox 0 0 1310.949 1615.5, scaled and simplified to viewBox "0 0 520 640"
 * using known geographic key-points (geographic coordinates mapped to SVG space):
 *   - Longitude 166°E→178°E maps to x 10→510
 *   - Latitude  34°S→47.5°S maps to y 10→630
 *
 * North Island: roughly triangular, widest at lower third, tapers north to Auckland
 *   peninsula and terminates at Cape Reinga in the NW / East Cape in the E
 * South Island: larger, elongated SW-NE, dominated by the Southern Alps spine
 * Stewart Island: small teardrop south of Foveaux Strait
 */

interface Props {
  /** Array of apiary region markers to render on the map */
  regions?: Array<{ label: string; x: number; y: number }>;
  class?: string;
}

const {
  regions = [
    { label: 'East Cape',       x: 390, y: 193 },
    { label: 'Coromandel',      x: 330, y: 215 },
    { label: 'Central Plateau', x: 295, y: 255 },
    { label: 'West Coast',      x: 175, y: 450 },
    { label: 'Southland',       x: 210, y: 565 },
  ],
  class: className,
} = Astro.props;
---

<!--
  NZ outline map – inline SVG
  viewBox: 0 0 520 640
  Paths derived from Wikimedia Commons CC0 simplified NZ outline.
-->
<svg
  viewBox="0 0 520 640"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-labelledby="nzmap-title"
  class:list={['nz-map', className]}
  style="width:100%;max-width:520px;height:auto;display:block;"
>
  <title id="nzmap-title">New Zealand</title>
  <defs>
    <!-- Soft glow filter for dot halos -->
    <filter id="nzmap-glow" x="-80%" y="-80%" width="260%" height="260%">
      <feGaussianBlur in="SourceGraphic" stdDeviation="3" result="blur" />
    </filter>
    <!-- Gold radial gradient for dot halo -->
    <radialGradient id="nzmap-dot-halo" cx="50%" cy="50%" r="50%">
      <stop offset="0%"   stop-color="#d8ac4e" stop-opacity="0.55" />
      <stop offset="100%" stop-color="#d8ac4e" stop-opacity="0" />
    </radialGradient>
  </defs>

  {/* ── NORTH ISLAND ─────────────────────────────────────────────── */}
  {/*
      Key geographic points mapped to viewBox 0 0 520 640
      Lon 166°E=10, 178°E=510  (scale: ~41.67 px/degree)
      Lat  34°S=10,  47.5°S=630 (scale: ~46.67 px/degree, S increases downward)

      Cape Reinga       172.7°E, 34.4°S  → (278, 29)
      Ninety Mile Beach coast going SW    → curves to (238, 55)
      Hokianga Harbour  173.4°E, 35.6°S  → (307, 85)
      Auckland Isthmus  174.7°E, 36.9°S  → (362, 146)
      Coromandel tip    175.7°E, 36.4°S  → (403, 123)
      East Cape         178.6°E, 37.7°S  → (510, 175)  ← easternmost
      Hawke's Bay       177.0°E, 39.5°S  → (427, 259)
      Cape Palliser      175.3°E, 41.6°S → (348, 357)   ← SE tip North Is.
      Farewell Spit     172.7°E, 40.5°S  → (278, 309)   ← NW top South Is.
      Wellington        174.8°E, 41.3°S  → (367, 342)
      Taranaki coast    174.2°E, 39.1°S  → (338, 240)
      Whanganui coast   175.0°E, 39.9°S  → (374, 277)
  */}
  <path
    aria-hidden="true"
    fill="rgba(216,172,78,0.06)"
    stroke="#d8ac4e"
    stroke-width="1.5"
    stroke-linejoin="round"
    stroke-linecap="round"
    d="
      M278,29
      C260,35 245,48 238,58
      C228,72 230,82 242,92
      C252,100 263,106 270,118
      C276,128 272,140 270,150
      C267,162 260,170 258,182
      C255,196 260,208 268,218
      C274,226 282,228 290,232
      C298,237 305,244 308,255
      C312,268 310,280 306,292
      C300,308 290,318 282,330
      C272,344 268,356 270,365
      C272,374 278,380 285,384
      C294,388 303,384 310,378
      C316,372 318,362 322,352
      C328,338 336,326 342,316
      C349,304 354,292 356,278
      C358,264 356,250 352,238
      C347,224 344,212 346,200
      C348,188 356,178 365,172
      C374,166 384,164 394,162
      C406,160 416,160 424,154
      C434,148 440,138 444,126
      C448,114 446,102 440,92
      C434,82 424,74 416,66
      C406,56 396,48 390,38
      C382,26 378,16 370,12
      C360,6 348,8 338,12
      C326,16 314,22 302,26
      C294,29 285,29 278,29
      Z
    "
  />

  {/* ── SOUTH ISLAND ─────────────────────────────────────────────── */}
  {/*
      Farewell Spit (NW)    172.7°E, 40.5°S → (278, 309)
      Nelson/Golden Bay     173.1°E, 41.0°S → (296, 333)
      Marlborough Sounds    174.3°E, 41.5°S → (348, 356)  ← matches Cook Strait S shore
      Kaikōura              173.7°E, 42.4°S → (322, 398)
      Banks Peninsula       172.7°E, 43.8°S → (278, 465)
      Timaru coast          171.2°E, 44.4°S → (215, 493)
      Dunedin               170.5°E, 45.9°S → (183, 563)
      Bluff / Foveaux       168.3°E, 46.6°S → (92,  595)
      Fiordland coast       167.3°E, 45.5°S → (51,  549)
      Jackson Bay           168.6°E, 43.9°S → (107, 469)
      Hokitika              170.9°E, 42.7°S → (203, 412)
      Westport              171.6°E, 41.7°S → (233, 364)
      Cape Farewell sea gap (small gap between islands)
  */}
  <path
    aria-hidden="true"
    fill="rgba(216,172,78,0.06)"
    stroke="#d8ac4e"
    stroke-width="1.5"
    stroke-linejoin="round"
    stroke-linecap="round"
    d="
      M278,318
      C285,318 294,322 302,328
      C312,336 320,346 330,354
      C342,362 354,366 362,374
      C370,382 374,394 374,406
      C374,420 370,432 364,444
      C356,458 346,468 336,478
      C324,490 312,500 302,512
      C292,524 284,538 278,552
      C272,566 270,580 268,592
      C264,604 258,614 250,620
      C240,626 228,626 218,622
      C206,616 196,606 188,594
      C178,580 170,564 162,550
      C152,534 142,520 132,508
      C120,494 108,482 98,468
      C86,452 76,434 66,418
      C56,400 48,382 46,364
      C44,346 48,328 56,314
      C64,300 76,290 88,282
      C100,274 114,270 126,268
      C140,266 154,268 166,272
      C178,276 188,282 198,290
      C210,298 220,308 230,316
      C244,324 258,326 270,322
      C274,320 276,318 278,318
      Z
    "
  />

  {/* ── STEWART ISLAND ───────────────────────────────────────────── */}
  {/*
      Stewart Island lies south of Foveaux Strait (~47°S, 168°E)
      Foveaux Strait gap at ~46.6°S → y≈595
      Stewart Island: roughly 46.8°S to 47.3°S, 167.5°E to 168.5°E
      Centre ≈ (85, 615), small teardrop shape
  */}
  <path
    aria-hidden="true"
    fill="rgba(216,172,78,0.06)"
    stroke="#d8ac4e"
    stroke-width="1.5"
    stroke-linejoin="round"
    stroke-linecap="round"
    d="
      M75,606
      C80,601 90,598 98,600
      C108,603 115,610 114,618
      C113,626 106,632 98,634
      C88,636 78,632 73,624
      C68,616 70,609 75,606
      Z
    "
  />

  {/* ── REGION MARKERS ───────────────────────────────────────────── */}
  {regions.map(({ label, x, y }) => (
    <g class="nzmap-region" aria-label={label}>
      {/* Halo glow circle */}
      <circle
        cx={x}
        cy={y}
        r="10"
        fill="url(#nzmap-dot-halo)"
        aria-hidden="true"
      />
      {/* Pulsing dot */}
      <circle
        cx={x}
        cy={y}
        r="4"
        fill="#d8ac4e"
        class="nzmap-dot"
        aria-hidden="true"
      />
      {/* Label */}
      <text
        x={x}
        y={y - 12}
        text-anchor="middle"
        font-family="sans-serif"
        font-size="7.5"
        fill="#cdbfa3"
        letter-spacing="0.08em"
        font-weight="500"
        aria-hidden="true"
        style="text-transform:uppercase;"
      >
        {label}
      </text>
    </g>
  ))}
</svg>

<style>
  .nz-map {
    overflow: visible;
  }

  @keyframes nzmap-pulse {
    0%   { r: 4; opacity: 1; }
    60%  { r: 6; opacity: 0.6; }
    100% { r: 4; opacity: 1; }
  }

  .nzmap-dot {
    animation: nzmap-pulse 2.8s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center;
  }

  /* Stagger dot animations per sibling index */
  .nzmap-region:nth-child(1) .nzmap-dot { animation-delay: 0s; }
  .nzmap-region:nth-child(2) .nzmap-dot { animation-delay: 0.56s; }
  .nzmap-region:nth-child(3) .nzmap-dot { animation-delay: 1.12s; }
  .nzmap-region:nth-child(4) .nzmap-dot { animation-delay: 1.68s; }
  .nzmap-region:nth-child(5) .nzmap-dot { animation-delay: 2.24s; }
</style>
