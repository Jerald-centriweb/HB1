---
/**
 * SilverFern.astro — New Zealand Silver Fern (Cyathea dealbata) frond as inline SVG
 *
 * A single fern frond: central rachis (stalk) with paired pinnae (leaflets) branching
 * off each side, curling tip at the top. The silver fern is a national symbol of
 * New Zealand. Rendered in gold (currentColor) on a transparent background.
 *
 * SVG is hand-crafted to match the botanical silhouette of the silver fern:
 *   - Stalk rises from base, curves slightly right
 *   - Pinnae pairs start small near the tip, grow larger toward the base
 *   - Each pinna is a gentle leaf shape with a slight curve
 *   - Tip curls in a small spiral (young frond / koru-like unfurling)
 *
 * viewBox: 0 0 100 200
 */

interface Props {
  /** Size in pixels (applied as width; height scales proportionally 1:2) */
  size?: number;
  /** Overall opacity */
  opacity?: number;
  class?: string;
}

const {
  size = 120,
  opacity = 1,
  class: className,
} = Astro.props;
---

<svg
  viewBox="0 0 100 200"
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size * 2}
  aria-hidden="true"
  focusable="false"
  class:list={['silver-fern', className]}
  style={`opacity:${opacity};display:block;`}
  color="#d8ac4e"
>
  <!--
    Silver Fern frond — viewBox 0 0 100 200
    The frond reads bottom to top: base → stalk → pinnae pairs → curling tip
    All paths use currentColor so the component colour is override-friendly.
  -->

  <!--
    Central rachis (stalk):
    Rises from (50,195) base, curves gently to the right as it goes up,
    then curls left at the tip finishing around (46,28).
  -->
  <path
    d="M50,195 C51,170 54,145 56,120 C58,95 58,72 54,52 C51,36 48,26 46,18 C44,12 43,6 46,3 C49,0 53,2 54,6"
    fill="none"
    stroke="currentColor"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"
  />

  <!-- Tip curl (small spiral at very top of frond) -->
  <path
    d="M54,6 C57,4 60,6 60,10 C60,14 57,17 54,17 C51,17 49,15 50,12"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    stroke-linecap="round"
  />

  <!--
    PINNAE PAIRS — left and right leaflets along the rachis.
    Each pair is positioned at a y-station along the stalk.
    Pairs numbered 1 (top/small) → 9 (bottom/large).

    Right pinnae curve away from stalk and taper to a point.
    Left pinnae mirror them on the other side.

    Each pinna path: starts at the attachment point on stalk,
    arcs out to full width, tapers to a pointed tip.
  -->

  <!-- Pair 1 — y≈28 (near tip, very small) -->
  <path d="M52,28 C56,26 62,24 63,22 C64,20 62,18 59,19 C56,20 53,24 52,28 Z"
        fill="currentColor" stroke="none" />
  <path d="M52,28 C48,26 42,24 41,22 C40,20 42,18 45,19 C48,20 51,24 52,28 Z"
        fill="currentColor" stroke="none" />

  <!-- Pair 2 — y≈40 (small) -->
  <path d="M53,40 C58,37 66,33 68,30 C70,27 68,24 64,26 C60,28 55,35 53,40 Z"
        fill="currentColor" stroke="none" />
  <path d="M53,40 C48,37 40,33 38,30 C36,27 38,24 42,26 C46,28 51,35 53,40 Z"
        fill="currentColor" stroke="none" />

  <!-- Pair 3 — y≈54 -->
  <path d="M54,54 C60,50 70,45 74,41 C77,37 74,33 70,35 C65,38 57,47 54,54 Z"
        fill="currentColor" stroke="none" />
  <path d="M54,54 C48,50 38,45 34,41 C31,37 34,33 38,35 C43,38 51,47 54,54 Z"
        fill="currentColor" stroke="none" />

  <!-- Pair 4 — y≈70 -->
  <path d="M55,70 C62,65 74,58 79,53 C83,48 80,43 75,46 C69,49 60,60 55,70 Z"
        fill="currentColor" stroke="none" />
  <path d="M55,70 C48,65 36,58 31,53 C27,48 30,43 35,46 C41,49 50,60 55,70 Z"
        fill="currentColor" stroke="none" />

  <!-- Pair 5 — y≈88 (middle, widening) -->
  <path d="M56,88 C64,82 78,73 84,67 C89,61 86,55 80,58 C73,62 63,74 56,88 Z"
        fill="currentColor" stroke="none" />
  <path d="M56,88 C48,82 34,73 28,67 C23,61 26,55 32,58 C39,62 49,74 56,88 Z"
        fill="currentColor" stroke="none" />

  <!-- Pair 6 — y≈108 -->
  <path d="M56,108 C65,101 81,90 88,83 C94,76 91,69 84,72 C76,76 64,89 56,108 Z"
        fill="currentColor" stroke="none" />
  <path d="M56,108 C47,101 31,90 24,83 C18,76 21,69 28,72 C36,76 48,89 56,108 Z"
        fill="currentColor" stroke="none" />

  <!-- Pair 7 — y≈128 -->
  <path d="M55,128 C65,120 83,108 90,100 C97,92 93,84 86,88 C78,92 64,106 55,128 Z"
        fill="currentColor" stroke="none" />
  <path d="M55,128 C45,120 27,108 20,100 C13,92 17,84 24,88 C32,92 46,106 55,128 Z"
        fill="currentColor" stroke="none" />

  <!-- Pair 8 — y≈150 (large lower pinnae) -->
  <path d="M54,150 C64,141 84,127 92,118 C99,109 96,100 88,104 C79,108 63,124 54,150 Z"
        fill="currentColor" stroke="none" />
  <path d="M54,150 C44,141 24,127 16,118 C9,109 12,100 20,104 C29,108 45,124 54,150 Z"
        fill="currentColor" stroke="none" />

  <!-- Pair 9 — y≈172 (lowest, largest) -->
  <path d="M52,172 C63,162 84,146 93,136 C101,126 98,115 89,120 C79,124 62,142 52,172 Z"
        fill="currentColor" stroke="none" />
  <path d="M52,172 C41,162 20,146 11,136 C3,126 6,115 15,120 C25,124 42,142 52,172 Z"
        fill="currentColor" stroke="none" />
</svg>

<style>
  .silver-fern {
    overflow: visible;
  }
</style>
