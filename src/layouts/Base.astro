---
export interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Honey Badgers — Pure Strength | New Zealand Mānuka Honey',
  description = 'Premium New Zealand Mānuka honey for the world — independently verified, fully traceable, and bold by nature. Certified MGO 100+ to 829+. Wholesale & export.',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Private client preview: keep it out of search results until launch. -->
    <meta name="robots" content="noindex, nofollow" />
    <link rel="icon" type="image/png" href="/assets/logo-outline.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,700;0,800;0,900&family=Archivo+Black&family=Barlow+Condensed:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <style is:global>
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: #0b0907;
        color: #f4ede0;
        font-family: 'Archivo', sans-serif;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      ::selection {
        background: #d8ac4e;
        color: #0b0907;
      }
      a {
        color: inherit;
        text-decoration: none;
      }
      @keyframes hb-float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-14px); }
      }
      @keyframes hb-drip {
        0% { transform: translateY(-6px); opacity: 0; }
        30% { opacity: 1; }
        100% { transform: translateY(18px); opacity: 0; }
      }
      @keyframes hb-spin {
        to { transform: rotate(360deg); }
      }
      @keyframes hb-pulse {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 1; }
      }
      @keyframes hb-orbit {
        to { transform: rotate(360deg); }
      }
      @keyframes hb-modalin {
        from { opacity: 0; transform: translateY(24px) scale(0.97); }
        to { opacity: 1; transform: none; }
      }
      @keyframes hb-flow {
        to { background-position: 0 -260px; }
      }
      @keyframes hb-pour {
        to { background-position: 0 64px; }
      }
      @keyframes hb-droplet {
        0% { top: 6%; opacity: 0; transform: translateX(-50%) rotate(45deg) scale(0.6); }
        12% { opacity: 1; }
        80% { opacity: 1; }
        100% { top: 84%; opacity: 0; transform: translateX(-50%) rotate(45deg) scale(1); }
      }
      @keyframes hb-wave {
        to { transform: translateX(-50%); }
      }
      @keyframes hb-shimmer {
        0%, 100% { opacity: 0.5; }
        50% { opacity: 1; }
      }
      .hb-track::-webkit-scrollbar {
        height: 6px;
      }
      .hb-track::-webkit-scrollbar-thumb {
        background: rgba(216, 172, 78, 0.4);
        border-radius: 3px;
      }

      /* Transition video wrapper: no height flash while hidden */
      #hb-transition-video-wrap[style*='display:none'] {
        height: 0 !important;
        min-height: 0 !important;
        overflow: hidden;
      }

      /* Respect prefers-reduced-motion */
      @media (prefers-reduced-motion: reduce) {
        #hb-hero-video,
        #hb-transition-video {
          animation: none !important;
          transition: none !important;
          transform: none !important;
          will-change: auto !important;
        }
      }
    </style>
  </body>
</html>
